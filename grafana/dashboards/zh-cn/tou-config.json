    {
      "id": 8,
      "type": "table",
      "title": "💰 最近 10 笔家充电费对账",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "TeslaMate"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "TeslaMate"
          },
          "rawSql": "\nSELECT\n  cp.id AS \"充电编号\",\n  date_trunc('second', cp.start_date AT TIME ZONE 'UTC') AS \"本地时间\",\n  ROUND(cp.charge_energy_added::numeric, 2) AS \"充电度数\",\n  cp.cost AS \"原费用 ¥\",\n  compute_tou_cost(cp.id) AS \"分时电价费用 ¥\",\n  ROUND((compute_tou_cost(cp.id) - cp.cost)::numeric, 2) AS \"差额 ¥\",\n  COALESCE(g.name, '(无)') AS \"充电点\"\nFROM charging_processes cp\nLEFT JOIN geofences g ON g.id = cp.geofence_id\nWHERE cp.car_id = $car_id\n  AND cp.geofence_id IN (SELECT DISTINCT geofence_id FROM tou_rates WHERE geofence_id IS NOT NULL)\nORDER BY cp.start_date DESC\nLIMIT 10\n",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "gridPos": {
        "x": 0,
        "y": 60,
        "w": 24,
        "h": 10
      }
    },
