  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "options": {
        "mode": "markdown",
        "content": "\n# ⚡ 分时电价配置\n\n**最快 3 步：**\n1. 「**🌆 一键导入城市模板**」选你城市（90% 用户够用）\n2. **不够用** → 用「**⚡ 一键填一整季节**」：只填**谷时段 + 峰时段 + 3 档单价**，平段自动占满剩余\n3. 看「**⏰ 24 小时电价分布**」 + 「**⚠ 配置审计**」核对覆盖\n\n> 时段格式：`22-7`（跨夜）或 `0-7, 23-24`（多段用逗号）。**两档电网**：峰时段留空、峰价填 0。\n\n> ⚡ **范围说明**：本配置只作用于**家充（交流慢充）**。**直流快充（超充 / 第三方快充）按桩侧上报金额计费**，不参与本表的分时重算 —— 因为快充价格随桩、随时段、随会员浮动，桩侧上报已是真实金额，覆盖反而会算错。\n"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 4
      }
    },
    {
      "id": 2,
      "type": "barchart",
      "title": "⏰ 24 小时电价分布（按所选充电点 + 今日）",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "TeslaMate"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "TeslaMate"
          },
          "rawSql": "\nWITH hours AS (\n  SELECT generate_series(0, 23) AS h\n),\nactive AS (\n  SELECT hour_start, hour_end, rate, label, valid_from, valid_to\n  FROM tou_rates\n  WHERE apply_to_dc = FALSE\n    AND geofence_id IS NOT DISTINCT FROM NULLIF('$geofence_filter', '')::INT\n    AND _tou_in_season((NOW() AT TIME ZONE '$__timezone')::DATE, valid_from, valid_to)\n)\nSELECT\n  lpad(h.h::TEXT, 2, '0') || ' 时' AS \"时点\",\n  COALESCE(\n    (SELECT rate\n     FROM active\n     WHERE (\n       (hour_start <= hour_end AND h.h >= hour_start AND h.h < hour_end) OR\n       (hour_start >  hour_end AND (h.h >= hour_start OR h.h < hour_end))\n     )\n     ORDER BY (CASE WHEN valid_from IS NOT NULL THEN 0 ELSE 1 END), rate DESC\n     LIMIT 1),\n    0\n  ) AS \"单价\",\n  COALESCE(\n    (SELECT label\n     FROM active\n     WHERE (\n       (hour_start <= hour_end AND h.h >= hour_start AND h.h < hour_end) OR\n       (hour_start >  hour_end AND (h.h >= hour_start OR h.h < hour_end))\n     )\n     ORDER BY (CASE WHEN valid_from IS NOT NULL THEN 0 ELSE 1 END), rate DESC\n     LIMIT 1),\n    '未配置'\n  ) AS \"标签\"\nFROM hours h\nORDER BY h.h\n",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "axisPlacement": "auto",
            "axisLabel": "",
            "axisColorMode": "text",
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 0,
            "axisBorderShow": false
          },
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.4
              },
              {
                "color": "orange",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 1.0
              }
            ]
          },
          "unit": "none",
          "decimals": 2,
          "min": 0,
          "displayName": "${__field.name} ¥/度"
        },
        "overrides": [
          {
            "matcher": {
