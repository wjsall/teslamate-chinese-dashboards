    {
      "id": 20,
      "type": "table",
      "title": "⚠ 配置审计",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "TeslaMate"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "TeslaMate"
          },
          "rawSql": "\nWITH issues AS (\n  SELECT severity, season, detail FROM audit_tou_config(NULLIF('$geofence_filter', '')::INT)\n)\nSELECT severity AS \"严重程度\", season AS \"季节\", detail AS \"详情\" FROM issues\nUNION ALL\nSELECT '✓ 配置完整', '-', '24 小时全覆盖、无重叠、月份完整'\nWHERE NOT EXISTS (SELECT 1 FROM issues)\n",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 6
      }
    },
    {
      "id": 3,
      "type": "table",
      "title": "📋 当前电价配置",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "TeslaMate"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "TeslaMate"
          },
          "rawSql": "\nSELECT\n  r.id AS \"编号\",\n  COALESCE(g.name, '(全局)') AS \"充电点\",\n  r.hour_start || ':00 - ' || r.hour_end || ':00' AS \"时段\",\n  r.rate AS \"单价 ¥/度\",\n  r.label AS \"标签\",\n  CASE WHEN r.apply_to_dc THEN '快充' ELSE '慢充' END AS \"类型\",\n  CASE WHEN r.valid_from IS NULL AND r.valid_to IS NULL THEN '全年'\n       ELSE COALESCE(to_char(r.valid_from, 'MM/DD'), '?') || ' ~ ' || COALESCE(to_char(r.valid_to, 'MM/DD'), '?') END AS \"季节\"\nFROM tou_rates r\nLEFT JOIN geofences g ON g.id = r.geofence_id\nORDER BY r.geofence_id NULLS FIRST, r.id\n",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 14,
        "h": 28
      }
    },
