      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "TeslaMate"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "with u as (\n  select *, coalesce(lag(start_date) over(order by start_date desc), now()) as next_start_date \n  from updates\n  where car_id = $car_id and $__timeFilter(start_date)\n),\nrng as (\n  SELECT\n\t  date_trunc('hour', timezone('UTC', date), '$__timezone') AS date,\n\t  (sum(${preferred_range}_battery_range_km)/ nullif(sum(usable_battery_level),0) * 100 ) AS \"电池续航\",\n\t  sum(case when action = 'Charge' then 1 else 0 end) as chg_ct\n  FROM (\n    select usable_battery_level, start_date as date, start_rated_range_km as rated_battery_range_km, start_ideal_range_km as ideal_battery_range_km, 'Drive' as action\n    from drives d\n    inner join positions p on d.start_position_id = p.id \n    where d.car_id = $car_id and $__timeFilter(start_date) and usable_battery_level > 0\n    union all\n    select end_battery_level as usable_battery_level, end_date, end_rated_range_km as rated_battery_range_km, end_ideal_range_km as ideal_battery_range_km, 'Charge' as action\n    FROM charging_processes p\n    where $__timeFilter(end_date) and p.car_id = $car_id\n  ) as data\n  GROUP BY 1\n),\nraw as (\n  select\t\n    u.start_date as time,\n    extract(EPOCH FROM u.end_date - u.start_date) AS update_duration_secs,\n    (date(u.start_date) - date(lag(u.start_date) OVER (ORDER BY u.start_date)))::float * 86400 AS since_last_update_secs,\n    split_part(u.version, ' ', 1) as version,\n    sum(r.chg_ct) as chg_ct,\n    convert_km(avg(r.\"电池续航\"), '$length_unit')::numeric(6,2) AS avg_${preferred_range}_range_${length_unit}\n  from u u\n  left join rng r\n\t  ON r.date between u.start_date and u.next_start_date\n  group by u.car_id,\n\t  u.start_date,\n\t  u.end_date,\n\t  next_start_date,\n\t  split_part(u.version, ' ', 1)\n)\nselect\n  time,\n  CASE\n    WHEN update_duration_secs < 60   THEN update_duration_secs::int::text || ' 秒'\n    WHEN update_duration_secs < 3600 THEN floor(update_duration_secs/60)::int::text || ' 分钟'\n    ELSE round(update_duration_secs/3600.0, 1)::text || ' 小时'\n  END AS update_duration,\n  CASE\n    WHEN since_last_update_secs IS NULL  THEN NULL\n    WHEN since_last_update_secs < 86400  THEN floor(since_last_update_secs/3600)::int::text || ' 小时'\n    WHEN since_last_update_secs < 2592000 THEN floor(since_last_update_secs/86400)::int::text || ' 天'\n    ELSE floor(since_last_update_secs/2592000)::int::text || ' 个月 ' || (floor(since_last_update_secs/86400)::int % 30)::text || ' 天'\n  END AS since_last_update,\n  version,\n  chg_ct,\n  avg_${preferred_range}_range_${length_unit}\nfrom raw",
          "refId": "A",
          "sql": {
