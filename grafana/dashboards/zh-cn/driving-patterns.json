      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "id": 8,
      "description": "按 5°C 区间统计平均每公里能耗，低温区间柱子更高说明冬季能耗上升。仅统计行程 > 5km 且有能耗消耗的记录；鼠标悬停可看每区间的行程数。",
      "options": {
        "barWidth": 0.8,
        "groupWidth": 0.7,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        },
        "xTickLabelRotation": 0
      },
      "pluginVersion": "11.6.1",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "TeslaMate"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  CONCAT((FLOOR(d.outside_temp_avg / 5) * 5)::int, '~', (FLOOR(d.outside_temp_avg / 5) * 5 + 5)::int, '°C') AS \"温度区间\",\n  ROUND(AVG((d.start_ideal_range_km - d.end_ideal_range_km) * c.efficiency / NULLIF(d.distance, 0) * 1000)::numeric, 0) AS \"平均能耗(Wh/km)\",\n  COUNT(*) AS \"行程数\"\nFROM drives d\nJOIN cars c ON c.id = d.car_id\nWHERE d.car_id = $car_id\n  AND $__timeFilter(d.start_date)\n  AND d.outside_temp_avg IS NOT NULL\n  AND d.distance > 5\n  AND d.start_ideal_range_km > d.end_ideal_range_km\nGROUP BY FLOOR(d.outside_temp_avg / 5)\nORDER BY FLOOR(d.outside_temp_avg / 5);",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
