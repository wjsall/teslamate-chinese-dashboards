          "rawSql": "WITH t AS (\n\tSELECT\n\t  CASE WHEN '$temp_unit' = 'C' THEN ROUND(cast(outside_temp_avg AS numeric) / 5, 0) * 5\n\t\t\t   WHEN '$temp_unit' = 'F' THEN ROUND(cast(convert_celsius(outside_temp_avg, '$temp_unit') AS numeric) / 10, 0) * 10\n\t\tEND AS outside_temp,\n\t\tsum(start_${preferred_range}_range_km - end_${preferred_range}_range_km) AS total_range,\n\t\tsum(distance) AS total_distance,\n\t\tsum(duration_min) as duration,\n\t\tsum(COALESCE(ascent, 0)) AS total_ascent,\n\t\tsum(COALESCE(descent, 0)) AS total_descent,\n\t\tcar_id\n\tFROM\n\t\tdrives\n\tWHERE\n\t\tdistance IS NOT NULL\n\t\tAND car_id = $car_id\n\t\tAND convert_km(distance::numeric, '$length_unit') >= $min_distance\n\t\tAND $__timeFilter(start_date)\n\t\tAND start_${preferred_range}_range_km - end_${preferred_range}_range_km > 0.1\n\tGROUP BY\n\t\t1,\n\t\tcar_id\n)\n\nSELECT\n\toutside_temp as outside_temp_$temp_unit,\n\tCASE\n\t  WHEN '$efficiency' = 'slope-adjusted' THEN\n\t\ttotal_distance * c.efficiency / NULLIF(\n\t\t  total_range * c.efficiency\n\t\t  + 2100 * 0.85 * 9.81 * total_descent / 3600 / 1000\n\t\t  - 2100 * 9.81 * total_ascent / 3600 / 1000\n\t\t, 0)\n\t  ELSE\n\t\ttotal_distance / NULLIF(total_range, 0)\n\tEND AS efficiency,\n\ttotal_range / convert_km(total_distance::numeric, '$length_unit') * c.efficiency * 1000 AS consumption_$length_unit,\n\tconvert_km(total_distance::numeric, '$length_unit') as total_distance_$length_unit,\n\t(convert_km(total_distance::numeric, '$length_unit') / duration) * 60 as avg_speed_$length_unit\nFROM\n\tt\nJOIN cars c ON t.car_id = c.id\nWHERE outside_temp IS NOT NULL\norder by 1 desc\n",
          "refId": "A",
          "sql": {
