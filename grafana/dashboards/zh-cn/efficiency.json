      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "TeslaMate"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "select\n  CASE\n    WHEN '$efficiency' = 'slope-adjusted' THEN\n      sum(\n        (start_${preferred_range}_range_km - end_${preferred_range}_range_km) * cars.efficiency\n        - 2100 * 9.81 * COALESCE(ascent, 0) / 3600 / 1000\n        + 2100 * 0.85 * 9.81 * COALESCE(descent, 0) / 3600 / 1000\n      ) / NULLIF(convert_km(sum(distance)::numeric, '$length_unit'), 0) * 1000\n    ELSE\n      sum((start_${preferred_range}_range_km - end_${preferred_range}_range_km) * cars.efficiency)\n      / NULLIF(convert_km(sum(distance)::numeric, '$length_unit'), 0) * 1000\n  END AS \"能耗\"\nfrom drives\ninner join cars on cars.id = car_id\nwhere\n  distance is not null and\n  start_${preferred_range}_range_km - end_${preferred_range}_range_km >= 0.1 and\n  $__timeFilter(start_date) and\n  car_id = $car_id",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "能耗（行驶）",
      "type": "stat"
    },
