      "title": "停车时长分布（按停车区间）",
      "type": "barchart",
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "TeslaMate"},
          "format": "table",
          "rawSql": "WITH sessions AS (\n  SELECT\n    end_date,\n    end_battery_level,\n    LEAD(start_date) OVER (PARTITION BY car_id ORDER BY start_date) AS next_start,\n    LEAD(start_battery_level) OVER (PARTITION BY car_id ORDER BY start_date) AS next_soc\n  FROM drives\n  WHERE car_id = $car_id AND end_date IS NOT NULL\n),\nbuckets AS (\n  SELECT\n    EXTRACT(EPOCH FROM (next_start - end_date))/3600 AS hours\n  FROM sessions\n  WHERE next_start IS NOT NULL AND next_start > end_date AND $__timeFilter(end_date)\n)\nSELECT\n  CASE\n    WHEN hours < 1 THEN '< 1小时'\n    WHEN hours < 4 THEN '1~4小时'\n    WHEN hours < 8 THEN '4~8小时'\n    WHEN hours < 12 THEN '8~12小时'\n    WHEN hours < 24 THEN '12~24小时'\n    WHEN hours < 48 THEN '1~2天'\n    ELSE '> 2天'\n  END AS duration_range,\n  COUNT(*) AS park_count\nFROM buckets\nGROUP BY\n  CASE\n    WHEN hours < 1 THEN 1\n    WHEN hours < 4 THEN 2\n    WHEN hours < 8 THEN 3\n    WHEN hours < 12 THEN 4\n    WHEN hours < 24 THEN 5\n    WHEN hours < 48 THEN 6\n    ELSE 7\n  END,\n  CASE\n    WHEN hours < 1 THEN '< 1小时'\n    WHEN hours < 4 THEN '1~4小时'\n    WHEN hours < 8 THEN '4~8小时'\n    WHEN hours < 12 THEN '8~12小时'\n    WHEN hours < 24 THEN '12~24小时'\n    WHEN hours < 48 THEN '1~2天'\n    ELSE '> 2天'\n  END\nORDER BY\n  CASE\n    WHEN hours < 1 THEN 1\n    WHEN hours < 4 THEN 2\n    WHEN hours < 8 THEN 3\n    WHEN hours < 12 THEN 4\n    WHEN hours < 24 THEN 5\n    WHEN hours < 48 THEN 6\n    ELSE 7\n  END;",
          "refId": "A"
        }
