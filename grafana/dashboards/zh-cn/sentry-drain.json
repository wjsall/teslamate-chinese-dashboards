      "title": "最耗电停车 TOP20（时间范围内）",
      "type": "table",
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "TeslaMate"},
          "format": "table",
          "rawSql": "WITH sessions AS (\n  SELECT\n    end_date,\n    end_battery_level,\n    LEAD(start_date) OVER (PARTITION BY car_id ORDER BY start_date) AS next_start,\n    LEAD(start_battery_level) OVER (PARTITION BY car_id ORDER BY start_date) AS next_soc\n  FROM drives\n  WHERE car_id = $car_id AND end_date IS NOT NULL\n)\nSELECT\n  TO_CHAR(end_date AT TIME ZONE 'Asia/Shanghai', 'YYYY-MM-DD HH24:MI') AS \"停车开始\",\n  TO_CHAR(next_start AT TIME ZONE 'Asia/Shanghai', 'YYYY-MM-DD HH24:MI') AS \"停车结束\",\n  ROUND(EXTRACT(EPOCH FROM (next_start - end_date))/3600, 1) AS \"停车时长(小时)\",\n  end_battery_level AS \"停车前SOC%\",\n  next_soc AS \"停车后SOC%\",\n  GREATEST(end_battery_level - next_soc, 0) AS \"掉电%\"\nFROM sessions\nWHERE next_start IS NOT NULL\n  AND next_start > end_date\n  AND $__timeFilter(end_date)\nORDER BY GREATEST(end_battery_level - next_soc, 0) DESC\nLIMIT 20;",
          "refId": "A"
        }
      ]
