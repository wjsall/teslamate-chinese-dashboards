      "gridPos": {"h": 7, "w": 24, "x": 0, "y": 1},
      "id": 2,
      "description": "所有车辆核心指标一览。通过右上角时间选择器可调整统计范围，默认显示近一年数据。",
      "options": {
        "cellHeight": "sm",
        "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false},
        "showHeader": true,
        "sortBy": []
      },
      "title": "综合对比一览表",
      "type": "table",
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "TeslaMate"},
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(c.name, CONCAT('VIN ', RIGHT(c.vin, 6))) AS \"车辆\",\n  COALESCE(d_stats.total_km, 0) AS \"总里程(km)\",\n  COALESCE(d_stats.drive_count, 0) AS \"行程次数\",\n  COALESCE(d_stats.avg_consumption, 0) AS \"平均能耗(Wh/km)\",\n  COALESCE(cp_stats.total_cost, 0) AS \"总充电费用(元)\",\n  ROUND((cp_stats.total_cost / NULLIF(d_stats.total_km, 0))::numeric, 4) AS \"每公里电费(元/km)\",\n  COALESCE(cp_stats.dc_ratio, 0) AS \"快充比例(%)\"\nFROM cars c\nLEFT JOIN (\n  SELECT d.car_id,\n    ROUND(SUM(d.distance)::numeric, 0) AS total_km,\n    COUNT(d.id) AS drive_count,\n    ROUND((SUM((d.start_ideal_range_km - d.end_ideal_range_km) * c2.efficiency) / NULLIF(SUM(d.distance), 0) * 1000)::numeric, 1) AS avg_consumption\n  FROM drives d\n  JOIN cars c2 ON c2.id = d.car_id\n  WHERE d.end_date IS NOT NULL\n    AND d.start_ideal_range_km > d.end_ideal_range_km\n    AND $__timeFilter(d.start_date)\n  GROUP BY d.car_id\n) d_stats ON d_stats.car_id = c.id\nLEFT JOIN (\n  SELECT cp.car_id,\n    ROUND(SUM(cp.cost)::numeric, 2) AS total_cost,\n    ROUND(\n      (COUNT(DISTINCT CASE WHEN fast.max_power > 22 THEN cp.id END)::numeric /\n       NULLIF(COUNT(DISTINCT cp.id), 0) * 100)::numeric, 1\n    ) AS dc_ratio\n  FROM charging_processes cp\n  LEFT JOIN LATERAL (\n    SELECT MAX(charger_power) AS max_power FROM charges WHERE charging_process_id = cp.id\n  ) fast ON true\n  WHERE $__timeFilter(cp.start_date)\n  GROUP BY cp.car_id\n) cp_stats ON cp_stats.car_id = c.id\nORDER BY COALESCE(d_stats.total_km, 0) DESC;",
          "refId": "A",
          "sql": {"columns": [{"parameters": [], "type": "function"}], "groupBy": [{"property": {"type": "string"}, "type": "groupBy"}], "limit": 50}
        }
      ]
    },
