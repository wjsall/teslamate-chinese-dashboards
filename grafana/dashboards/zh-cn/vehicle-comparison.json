          "rawSql": "SELECT\n  COALESCE(c.name, CONCAT('VIN ', RIGHT(c.vin, 6))) AS \"车辆\",\n  ROUND((SUM((d.start_ideal_range_km - d.end_ideal_range_km) * c.efficiency) / NULLIF(SUM(d.distance), 0) * 1000)::numeric, 1) AS \"平均能耗(Wh/km)\"\nFROM cars c\nLEFT JOIN drives d ON d.car_id = c.id\n  AND d.end_date IS NOT NULL\n  AND d.start_ideal_range_km > d.end_ideal_range_km\n  AND $__timeFilter(d.start_date)\nGROUP BY c.id, c.name, c.vin\nHAVING SUM(d.distance) > 0\nORDER BY \"平均能耗(Wh/km)\" ASC NULLS LAST;",
