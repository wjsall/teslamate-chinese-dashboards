      "id": 12,
      "title": "电池健康对比",
      "type": "row"
    },
    {
      "datasource": {"type": "grafana-postgresql-datasource", "uid": "TeslaMate"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "decimals": 1,
          "mappings": [],
          "max": 100,
          "min": 70,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "light-red", "value": null},
              {"color": "#EAB839", "value": 80},
              {"color": "light-green", "value": 90}
            ]
          },
          "unit": "%"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 36},
      "id": 13,
      "description": "与官方电池健康度面板算法一致：取最近100次充电的平均容量 / 历史最大容量 × 100%。渐变色展示，与官方电池健康度页面视觉风格一致。",
      "options": {
        "displayMode": "gradient",
        "legend": {"calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": false},
        "maxVizHeight": 300,
        "minVizHeight": 10,
        "minVizWidth": 0,
        "namePlacement": "auto",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": true},
        "showUnfilled": true,
        "sizing": "auto",
        "valueMode": "color"
      },
      "title": "各车电池健康度(%)",
      "type": "bargauge",
      "targets": [
        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "TeslaMate"},
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH max_cap AS (\n  SELECT\n    cp.car_id,\n    MAX(c.rated_battery_range_km * (cars.efficiency * 100) / c.usable_battery_level) AS capacity\n  FROM charging_processes cp\n  INNER JOIN (\n    SELECT charging_process_id, MAX(date) AS last_date\n    FROM charges WHERE usable_battery_level > 0\n    GROUP BY charging_process_id\n  ) gcharges ON cp.id = gcharges.charging_process_id\n  INNER JOIN charges c ON c.charging_process_id = cp.id AND c.date = gcharges.last_date\n  INNER JOIN cars ON cars.id = cp.car_id\n  WHERE cp.end_date IS NOT NULL\n    AND cp.charge_energy_added >= cars.efficiency * 100\n  GROUP BY cp.car_id\n),\ncur_cap AS (\n  SELECT car_id, AVG(capacity) AS capacity\n  FROM (\n    SELECT\n      cp.car_id,\n      c.rated_battery_range_km * (cars.efficiency * 100) / c.usable_battery_level AS capacity,\n      ROW_NUMBER() OVER (PARTITION BY cp.car_id ORDER BY cp.end_date DESC, c.date DESC) AS rn\n    FROM charging_processes cp\n    INNER JOIN charges c ON c.charging_process_id = cp.id\n    INNER JOIN cars ON cars.id = cp.car_id\n    WHERE cp.end_date IS NOT NULL\n      AND cp.charge_energy_added >= cars.efficiency * 100\n      AND c.usable_battery_level > 0\n  ) t\n  WHERE rn <= 100\n  GROUP BY car_id\n)\nSELECT\n  COALESCE(cars.name, CONCAT('VIN ', RIGHT(cars.vin, 6))) AS \"车辆\",\n  ROUND(LEAST(100, cur_cap.capacity / NULLIF(max_cap.capacity, 0) * 100)::numeric, 1) AS \"电池健康度(%)\"\nFROM cars\nLEFT JOIN max_cap ON max_cap.car_id = cars.id\nLEFT JOIN cur_cap ON cur_cap.car_id = cars.id\nWHERE max_cap.capacity IS NOT NULL\nORDER BY \"电池健康度(%)\" DESC NULLS LAST;",
          "refId": "A",
