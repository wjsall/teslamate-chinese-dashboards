          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('minute', timezone('UTC', date), '$__timezone') as time,\n  lat_for_map('${map_url}', avg(latitude), avg(longitude)) as latitude,\n  lng_for_map('${map_url}', avg(latitude), avg(longitude)) as longitude\nFROM\n  positions\nWHERE\n  car_id = $car_id AND $__timeFilter(date) and ideal_battery_range_km is not null\nGROUP BY 1\nORDER BY 1",
          "refId": "Positions",
          "sql": {
