          "rawSql": "SELECT\n  CASE WHEN fuel_cost > 0 THEN\n    ROUND(((fuel_cost - charge_cost) / fuel_cost * 100)::numeric, 1)\n  ELSE 0 END AS save_pct\nFROM (\n  SELECT\n    COALESCE(SUM(d.distance), 0) * $fuel_efficiency / 100.0 * $fuel_price AS fuel_cost,\n    COALESCE((SELECT SUM(cost) FROM charging_processes WHERE car_id = $car_id AND cost IS NOT NULL AND $__timeFilter(start_date)), 0) AS charge_cost\n  FROM drives d\n  WHERE d.car_id = $car_id AND $__timeFilter(d.start_date)\n) sub;",
          "refId": "A",
          "sql": {"columns": [{"parameters": [], "type": "function"}], "groupBy": [{"property": {"type": "string"}, "type": "groupBy"}], "limit": 50}
        }
      ],
