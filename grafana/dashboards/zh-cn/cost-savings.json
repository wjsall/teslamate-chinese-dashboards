        {
          "datasource": {"type": "grafana-postgresql-datasource", "uid": "TeslaMate"},
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  ROUND(SUM(CASE WHEN EXTRACT(HOUR FROM start_date) = 23 OR EXTRACT(HOUR FROM start_date) BETWEEN 0 AND 6 THEN cost ELSE 0 END)::numeric, 2) AS \"深夜谷时(23-07点)\",\n  ROUND(SUM(CASE WHEN EXTRACT(HOUR FROM start_date) BETWEEN 7 AND 8 THEN cost ELSE 0 END)::numeric, 2) AS \"早高峰(07-09点)\",\n  ROUND(SUM(CASE WHEN EXTRACT(HOUR FROM start_date) BETWEEN 9 AND 11 THEN cost ELSE 0 END)::numeric, 2) AS \"上午平时(09-12点)\",\n  ROUND(SUM(CASE WHEN EXTRACT(HOUR FROM start_date) BETWEEN 12 AND 13 THEN cost ELSE 0 END)::numeric, 2) AS \"午间(12-14点)\",\n  ROUND(SUM(CASE WHEN EXTRACT(HOUR FROM start_date) BETWEEN 14 AND 16 THEN cost ELSE 0 END)::numeric, 2) AS \"下午平时(14-17点)\",\n  ROUND(SUM(CASE WHEN EXTRACT(HOUR FROM start_date) BETWEEN 17 AND 19 THEN cost ELSE 0 END)::numeric, 2) AS \"晚高峰(17-20点)\",\n  ROUND(SUM(CASE WHEN EXTRACT(HOUR FROM start_date) BETWEEN 20 AND 22 THEN cost ELSE 0 END)::numeric, 2) AS \"晚间(20-23点)\"\nFROM charging_processes\nWHERE car_id = $car_id AND cost IS NOT NULL AND $__timeFilter(start_date);",
          "refId": "A",
          "sql": {"columns": [{"parameters": [], "type": "function"}], "groupBy": [{"property": {"type": "string"}, "type": "groupBy"}], "limit": 50}
        }
      ],
      "description": "按充电开始时间段统计费用分布。需在 TeslaMate 中手动录入每次充电费用后才会显示数据。",
