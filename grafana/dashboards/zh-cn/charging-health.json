      "pluginVersion": "11.6.1",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "TeslaMate"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  GREATEST(0, LEAST(100,\n    50\n    + CASE\n        WHEN cs.lfp_battery THEN\n          CASE WHEN full_pct >= 0.95 THEN 30 WHEN full_pct >= 0.8 THEN 15 WHEN full_pct >= 0.6 THEN 0 ELSE -15 END\n        ELSE\n          CASE WHEN full_pct <= 0.05 THEN 30 WHEN full_pct <= 0.15 THEN 15 WHEN full_pct <= 0.3 THEN 0 ELSE -15 END\n      END\n    + CASE WHEN low_pct <= 0.05 THEN 30 WHEN low_pct <= 0.1 THEN 15 WHEN low_pct <= 0.2 THEN 0 ELSE -15 END\n  ))::int AS score\nFROM (\n  SELECT\n    ROUND(AVG(CASE WHEN end_battery_level >= 95 THEN 1.0 ELSE 0.0 END), 3) AS full_pct,\n    ROUND(AVG(CASE WHEN start_battery_level <= 15 THEN 1.0 ELSE 0.0 END), 3) AS low_pct\n  FROM charging_processes\n  WHERE car_id = $car_id AND $__timeFilter(start_date)\n) s\nCROSS JOIN (\n  SELECT cs.lfp_battery\n  FROM cars c\n  JOIN car_settings cs ON cs.id = c.settings_id\n  WHERE c.id = $car_id\n) cs",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "description": "评分说明：自动识别电池类型并调整评分逻辑。【三元锂】避免充满(95%+)、避免低电(<15%)充电；【磷酸铁锂】鼓励常充满(95%+)校准BMS、避免低电(<15%)充电。满分100分，80+优秀，60-80良好，<60需改善。",
      "title": "充电习惯综合评分 (0-100)",
      "type": "gauge"
    },
